# LLM endpoint (OpenAI-compatible)
LLM_BASE_URL=http://localhost:30000/v1
LLM_API_KEY=sk-no-key-required
LLM_MODEL=openai/gpt-oss-120b
LLM_REASONING_EFFORT=medium
LLM_TEMPERATURE=0
LLM_MAX_COMPLETION_TOKENS=5000

# OpenRouter fallback (used when local endpoint unavailable)
OPENROUTER_API_KEY="your-api-key"
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Docker / RISC-V toolchain
DOCKER_IMAGE=luispimo/riscv-toolchain:arm64-2025-10-20
RISCVCC=riscv64-unknown-elf-gcc
RISCVCXX=riscv64-unknown-elf-g++
VLEN=128

# SSH host for real hardware validation
SSH_HOST=final
REMOTE_DIR=/tmp/sse2rvv

# Translation pipeline
REACT_MAX_STEPS=15
LLM_VALIDATION_RETRIES=2
VALIDATION_TIMEOUT_SECONDS=120
